-- pg_orca olap_mdqa regression tests
-- Ported from Greenplum testrepo/olap/olap_mdqa
-- Tests: ROLLUP, CUBE, GROUPING SETS, GROUPING(), GROUP_ID(), complex aggregates
-- Schema: customer, vendor, product, sale, sale_ord, util (small dataset)
LOAD 'pg_orca';
SET pg_orca.enable_orca = on;
SET client_min_messages = warning;
-- GROUP_ID() compatibility shim: PG18 does not have GROUP_ID().
-- In GPDB it returns the duplicate count for a grouping set row.
-- We define it as always returning 0 (no duplicates in single-node PG).
-- Queries with HAVING GROUP_ID() > 0 will return empty results, which is correct.
CREATE OR REPLACE FUNCTION group_id() RETURNS bigint
    LANGUAGE sql STABLE CALLED ON NULL INPUT
    AS $$ SELECT 0::bigint $$;
--
-- STANDARD DATA FOR olap_* TESTS.
--
drop table if exists customer;
drop table if exists vendor;
drop table if exists product;
drop table if exists sale;
drop table if exists sale_ord;
drop table if exists util;
create table customer 
(
	cn int not null,
	cname text not null,
	cloc text,
	
	primary key (cn)
	
);
create table vendor 
(
	vn int not null,
	vname text not null,
	vloc text,
	
	primary key (vn)
	
);
create table product 
(
	pn int not null,
	pname text not null,
	pcolor text,
	
	primary key (pn)
	
);
create table sale
(
	cn int not null,
	vn int not null,
	pn int not null,
	dt date not null,
	qty int not null,
	prc float not null,
	
	primary key (cn, vn, pn)
	
);
create table sale_ord
(
        ord int not null,
	cn int not null,
	vn int not null,
	pn int not null,
	dt date not null,
	qty int not null,
	prc float not null,
	
	primary key (cn, vn, pn)
	
);
create table util
(
	xn int not null,
	
	primary key (xn)
	
);
