-- query29.sql
-- ###### Queries involving STDDEV() function ###### --
SELECT sale.cn*2 as newalias1,CASE WHEN sale.dt < '0010-1-1' THEN 1 ELSE 2 END as newalias2,sale.prc as newalias3,GROUP_ID(), TO_CHAR(COALESCE(STDDEV(DISTINCT floor(sale.prc*sale.vn)),0),'99999999.9999999'),TO_CHAR(COALESCE(COUNT(DISTINCT floor(sale.pn)),0),'99999999.9999999'),TO_CHAR(COALESCE(AVG(DISTINCT floor(sale.vn)),0),'99999999.9999999') 
FROM sale
GROUP BY (),sale.cn,sale.dt,sale.prc; -- mvd 1,2,3,4 -> 5,6
 newalias1 | newalias2 | newalias3 | group_id |      to_char      |      to_char      |      to_char      
